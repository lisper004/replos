(use-modules (ice-9 ftw)
	     (ice-9 readline)
             (ice-9 colorized)
	     (system repl common))	

;; (define %auto-compilation-options (cons '#:never %auto-compilation-options))

(define (todir)
  (chdir (string-append (getenv "HOME") "/.replos/"))
  (format #t "BOOTED IN: ~a\n" (getcwd)))

(todir)

(load (string-append (getenv "HOME") "/.replos/core/boot/init.scm"))
;;(primitive-load (string-append (getenv "HOME") "/.replos/core/boot/init.scm"))

(activate-readline)

(activate-colorized)

