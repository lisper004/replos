(define-syntax block
  (lambda (x)
    (syntax-case x ()
      ((_ name . body)
       #'(call-with-current-continuation
          (lambda (return-from-name)
            (dynamic-wind
              (lambda () #t)
              (lambda () . body)
              (lambda () #t))))))))

(define-syntax return-from
  (lambda (x)
    (syntax-case x ()
      ((_ name value)
       #'(name value))
      ((_ name)
       #'(name #f)))))

(define-syntax return
  (lambda (x)
    (syntax-case x ()
      ((_ value)
       #'(return-from return-from-block value))
      ((_)
       #'(return-from return-from-block #f)))))

(define-syntax flet
  (lambda (x)
    (syntax-case x ()
      ((_ ((name args body ...) ...) . body2)
       #'(letrec-syntax
           ((name (syntax-rules ()
                    ((_ . args) body ...)))
            ...)
           . body2)))))

(define-syntax labels
  (lambda (x)
    (syntax-case x ()
      ((_ ((name args body ...) ...) . body2)
       #'(letrec ((name (lambda args body ...)) ...)
           . body2)))))

(define-syntax multiple-value-bind
  (lambda (x)
    (syntax-case x ()
      ((_ (var ...) expr . body)
       #'(receive (var ...) expr
           . body)))))

(define-syntax with-open-file
  (lambda (x)
    (syntax-case x ()
      ((_ (stream filename direction . options) . body)
       #'(call-with-input-file filename
           (lambda (stream)
             . body))))))

(define (zerop x) (zero? x))
(define (nullp x) (null? x))
(define (listp x) (list? x))
(define (atom x) (not (pair? x)))
(define (consp x) (pair? x))
(define (oddp x) (odd? x))
(define (evenp x) (even? x))

(define first car)
(define second cadr)
(define third caddr)
(define fourth cadddr)
(define fifth (lambda (x) (car (cddddr x))))

(define rest cdr)
(define (butlast lst) (drop-right lst 1))
(define (nthcdr n lst) (drop lst n))
(define (last lst) (list (car (take-right lst 1))))
