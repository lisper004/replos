;;; mount.scm

;; ============================================================
;; Base
;; ============================================================

(define (mount device mountpoint . options)
  (let ((cmd (string-append "sudo mount " 
                            (if (null? options) "" (car options))
                            " " device " " mountpoint)))
    (system cmd)))

(define (umount target)
  (system (string-append "sudo umount " target)))

(define (mount-list)
  (system "mount | column -t"))

;; ============================================================
;; Other functions
;; ============================================================

(define (mount-all)
  (system "sudo mount -a"))

(define (mount-bind source target)
  (system (string-append "sudo mount --bind " source " " target)))

(define (mount-remount dir options)
  (system (string-append "sudo mount -o remount," options " " dir)))

(define (mount-loop file mountpoint)
  (system (string-append "sudo mount -o loop " file " " mountpoint)))

;; ============================================================
;; Work with disks
;; ============================================================

(define (disk-list)
  (system "lsblk -o NAME,SIZE,TYPE,MOUNTPOINT"))

(define (disk-info device)
  (system (string-append "sudo fdisk -l " device)))

(define (disk-usage)
  (system "df -h"))

(define (disk-free)
  (system "df -h --total"))

;; ============================================================
;; MKFS Tools
;; ============================================================

(define (mkfs-ext4 device)
  (display (string-append ">> WARNING: This will erase " device "!\n"))
  (display ">> Continue? (yes/no): ")
  (if (string=? (read-line) "yes")
      (system (string-append "sudo mkfs.ext4 -F " device))
      (display ">> Aborted.\n")))

(define (mkfs-fat32 device)
  (display (string-append ">> WARNING: This will erase " device "!\n"))
  (display ">> Continue? (yes/no): ")
  (if (string=? (read-line) "yes")
      (system (string-append "sudo mkfs.vfat -F 32 " device))
      (display ">> Aborted.\n")))

;; ============================================================
;; Work with SWAP
;; ============================================================

(define (swap-on device)
  (system (string-append "sudo swapon " device)))

(define (swap-off device)
  (system (string-append "sudo swapoff " device)))

(define (swap-list)
  (system "swapon --show"))

;; ============================================================
;; fsck
;; ============================================================

(define (fsck device)
  (display (string-append ">> Checking " device "...\n"))
  (system (string-append "sudo fsck -y " device)))

;; ============================================================
;; Utils for RING
;; ============================================================

(define (mount-ring-root)
  (let ((part (read-line ">> Enter root partition (e.g., /dev/sda2): ")))
    (mount part "/mnt" "-t ext4")
    (display "Root mounted to /mnt\n")))

(define (mount-ring-boot)
  (let ((part (read-line ">> Enter boot partition (e.g., /dev/sda1): ")))
    (mount part "/mnt/boot")
    (display ">> Boot mounted to /mnt/boot\n")))

(define (mount-all-for-install)
  (mount-ring-root)
  (let ((yn (read-line ">> Do you have a separate boot partition? (y/n): ")))
    (when (string=? yn "y")
      (mount-ring-boot))))

;; ============================================================
;; Welcome message
;; ============================================================

(display "\n >> Mount utilities loaded <<\n")
(display "  (mount \"/dev/sda1\" \"/mnt\")\n")
(display "  (umount \"/mnt\")\n")
(display "  (disk-list) (disk-usage) (disk-info \"/dev/sda\")\n")
(display "  (mount-all-for-install) - for RING installation\n")
